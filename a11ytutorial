    <div class="exstatus pending" id="vo_st_${id}" style="margin:0 1.25rem 1.25rem"><span class="stic">💡</span><span>Enable VoiceOver (⌘F5), then work through each step. Click "✓ Done" after completing each one.</span></div>
  </div>`;
}
function voMark(practiceId, stepId, total){
  const li = document.getElementById(`vos_${practiceId}_${stepId}`);
  if(!li || li.classList.contains('vo-step-done')) return;
  li.classList.add('vo-step-done');
  li.querySelector('.vo-check-btn').disabled = true;
  const list = document.getElementById(`volist_${practiceId}`);
  const doneCount = list.querySelectorAll('.vo-step-done').length;
  const st = document.getElementById(`vo_st_${practiceId}`);
  if(doneCount === total){
    document.getElementById(`vo_icon_${practiceId}`).textContent = '✅';
    st.className = 'exstatus success';
    st.innerHTML = '<span class="stic">🎉</span><span>All steps complete! Great work with VoiceOver.</span>';
    completeEx();
  } else {
    st.className = 'exstatus hint';
    st.innerHTML = `<span class="stic">💡</span><span>${doneCount} of ${total} steps done — keep going!</span>`;
  }
}

