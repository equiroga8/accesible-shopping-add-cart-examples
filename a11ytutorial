<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Accessibility Tutorial</title>
<style>
:root{--pri:#6366f1;--pri-d:#4f46e5;--pri-l:#eef2ff;--suc:#10b981;--suc-l:#d1fae5;--war:#f59e0b;--war-l:#fef3c7;--err:#ef4444;--err-l:#fee2e2;--side:#1e1b4b;--side-h:#312e81;--side-a:#4f46e5;--bg:#f8fafc;--sur:#fff;--txt:#0f172a;--muted:#64748b;--bdr:#e2e8f0;--r:8px;}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{font-size:16px;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--txt);line-height:1.6;min-height:100vh;}
:focus-visible{outline:3px solid var(--pri);outline-offset:2px;border-radius:3px;}
.hidden{display:none!important;}

/* WELCOME */
.welcome{min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#1e1b4b 0%,#4f46e5 60%,#7c3aed 100%);padding:1.5rem;}
.wcard{background:#fff;border-radius:16px;padding:2.5rem 2rem;max-width:620px;width:100%;text-align:center;box-shadow:0 25px 60px rgba(0,0,0,.3);}
.wcard .wi{font-size:3.5rem;margin-bottom:.75rem;}
.wcard h1{font-size:1.9rem;font-weight:800;margin-bottom:.4rem;}
.wcard>p{color:var(--muted);margin-bottom:1.5rem;}
.wtopics{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;margin-bottom:1.5rem;}
.wtopic{background:var(--pri-l);border-radius:var(--r);padding:.9rem .5rem;}
.wtopic .ti{font-size:1.6rem;margin-bottom:.3rem;}
.wtopic p{font-size:.8rem;color:var(--pri-d);font-weight:600;margin:0;}
.wmeta{font-size:.82rem;color:var(--muted);margin-bottom:1.5rem!important;}
.btn-start{background:var(--pri);color:#fff;border:none;padding:.9rem 2.5rem;font-size:1.05rem;font-weight:700;border-radius:50px;cursor:pointer;transition:background .2s,transform .1s;display:inline-flex;align-items:center;gap:.4rem;}
.btn-start:hover{background:var(--pri-d);transform:translateY(-1px);}
.btn-start:active{transform:translateY(0);}

/* LAYOUT */
.app{display:flex;height:100vh;overflow:hidden;}
.sidebar{width:290px;background:var(--side);color:#a5b4fc;display:flex;flex-direction:column;overflow:hidden;flex-shrink:0;transition:width .3s ease;}
.sidebar.collapsed{width:0;}
.sh{padding:1rem;border-bottom:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:space-between;}
.sh-title{font-weight:700;font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;color:#fff;}
.sh-close{background:none;border:1px solid rgba(165,180,252,.25);border-radius:var(--r);padding:.3rem .55rem;cursor:pointer;color:rgba(165,180,252,.7);font-size:.9rem;}
.sp{padding:.65rem 1rem;border-bottom:1px solid rgba(255,255,255,.1);}
.sp-lbl{display:flex;justify-content:space-between;font-size:.72rem;color:#a5b4fc;margin-bottom:.35rem;}
.sp-bar{height:4px;background:rgba(255,255,255,.12);border-radius:2px;overflow:hidden;}
.sp-fill{height:100%;background:var(--pri);border-radius:2px;transition:width .4s ease;}
.snav{flex:1;overflow-y:auto;padding:.4rem 0;}
.snav::-webkit-scrollbar{width:3px;}
.snav::-webkit-scrollbar-thumb{background:rgba(255,255,255,.12);border-radius:2px;}
.chdr{padding:.6rem 1rem .15rem;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:rgba(165,180,252,.5);margin-top:.4rem;}
.litem{display:flex;align-items:center;gap:.65rem;padding:.55rem 1rem;cursor:pointer;transition:background .15s;border:none;background:none;color:#a5b4fc;width:100%;text-align:left;font-size:.85rem;}
.litem:hover{background:var(--side-h);color:#fff;}
.litem.active{background:var(--side-a);color:#fff;}
.litem.done{color:rgba(165,180,252,.75);}
.lstatus{width:20px;height:20px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.62rem;border:2px solid rgba(165,180,252,.25);}
.litem.done .lstatus{background:var(--suc);border-color:var(--suc);color:#fff;}
.litem.active .lstatus{border-color:#fff;background:#fff;color:var(--pri-d);}
.ltext{flex:1;line-height:1.3;font-size:.82rem;}

/* MAIN */
.main{flex:1;overflow-y:auto;display:flex;flex-direction:column;}
.mhdr{padding:.85rem 1.25rem;background:var(--sur);border-bottom:1px solid var(--bdr);display:flex;align-items:center;gap:.85rem;position:sticky;top:0;z-index:10;}
.mtog{background:none;border:1px solid var(--bdr);border-radius:var(--r);padding:.35rem .55rem;cursor:pointer;font-size:.95rem;color:var(--txt);}
.mhdr-info{flex:1;}
.mhdr-ch{font-size:.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;}
.mhdr-t{font-size:.95rem;font-weight:700;color:var(--txt);}
.mhdr-p{font-size:.72rem;color:var(--muted);white-space:nowrap;}
.lbody{flex:1;padding:2rem;max-width:800px;margin:0 auto;width:100%;}
.lfooter{padding:1.25rem 2rem;border-top:1px solid var(--bdr);background:var(--sur);display:flex;align-items:center;justify-content:space-between;gap:1rem;position:sticky;bottom:0;}

/* CONTENT */
.lcontent{animation:fadeIn .3s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
.lcontent h2{font-size:1.65rem;font-weight:800;margin-bottom:.4rem;}
.lmeta{display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;margin-bottom:1.25rem;}
.badge{padding:.2rem .55rem;border-radius:20px;font-size:.72rem;font-weight:600;}
.bc{background:var(--pri-l);color:var(--pri-d);}
.be{background:#d1fae5;color:#065f46;}
.bm{background:var(--war-l);color:#92400e;}
.bh{background:var(--err-l);color:#991b1b;}
.mob-badge{display:inline-flex;align-items:center;gap:.25rem;background:var(--side);color:#a5b4fc;padding:.2rem .55rem;border-radius:20px;font-size:.72rem;font-weight:600;}
.intro{background:var(--sur);border-radius:var(--r);padding:1.25rem;margin-bottom:1.25rem;border:1px solid var(--bdr);box-shadow:0 1px 3px rgba(0,0,0,.06);}
.intro p{margin-bottom:.6rem;}
.intro p:last-child{margin-bottom:0;}
.stitle{font-size:.9rem;font-weight:700;color:var(--txt);margin:1.4rem 0 .65rem;padding-bottom:.4rem;border-bottom:2px solid var(--bdr);}
kbd{display:inline-block;background:#1e293b;color:#fff;border-radius:5px;padding:.12rem .45rem;font-family:monospace;font-size:.82rem;font-weight:600;border-bottom:3px solid #0f172a;white-space:nowrap;}
code{background:#f1f5f9;color:#7c3aed;padding:.1rem .35rem;border-radius:4px;font-size:.85rem;}
.ibox{border-radius:var(--r);padding:.9rem 1rem;margin-bottom:1rem;display:flex;gap:.65rem;border:1px solid;}
.ibox.tip{background:#eff6ff;border-color:#bfdbfe;}
.ibox.warn{background:var(--war-l);border-color:#fcd34d;}
.ibox.note{background:var(--pri-l);border-color:#c7d2fe;}
.ibox-ic{font-size:1.1rem;flex-shrink:0;margin-top:.1rem;}
.ibox-c{font-size:.85rem;color:var(--txt);}
.ibox-c strong{color:#1e293b;}

/* COMMANDS & GESTURES */
.cgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.65rem;margin-bottom:1.25rem;}
.ccard{background:var(--sur);border:1px solid var(--bdr);border-radius:var(--r);padding:.9rem;box-shadow:0 1px 3px rgba(0,0,0,.06);}
.ccard .ckeys{display:flex;flex-wrap:wrap;gap:.2rem;margin-bottom:.4rem;align-items:center;}
.ccard .cdesc{font-size:.82rem;color:var(--muted);}
.ggrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:.85rem;margin-bottom:1.25rem;}
.gcard{background:var(--sur);border:1px solid var(--bdr);border-radius:var(--r);padding:1rem;display:flex;gap:.85rem;align-items:flex-start;box-shadow:0 1px 3px rgba(0,0,0,.06);}
.gic{font-size:1.6rem;flex-shrink:0;width:44px;height:44px;display:flex;align-items:center;justify-content:center;background:var(--pri-l);border-radius:var(--r);}
.ginf h4{font-size:.875rem;font-weight:700;margin-bottom:.2rem;}
.ginf p{font-size:.8rem;color:var(--muted);}

/* EXERCISE */
.exarea{background:var(--sur);border:2px solid var(--pri);border-radius:var(--r);margin-bottom:1.25rem;overflow:hidden;}
.exhdr{background:var(--pri-l);padding:.65rem 1.1rem;border-bottom:2px solid var(--pri);display:flex;align-items:center;gap:.45rem;}
.exhdr h3{font-size:.83rem;font-weight:700;color:var(--pri-d);flex:1;}
.exbody{padding:1.25rem;}
.extask{background:#fff7ed;border:1px solid #fed7aa;border-radius:var(--r);padding:.85rem 1rem;margin-bottom:1rem;}
.extask p{font-size:.875rem;color:#7c2d12;margin:0;}
.extask strong{color:#9a3412;}
.keyind{display:flex;align-items:center;gap:.45rem;margin-bottom:.85rem;font-size:.78rem;color:var(--muted);}
.kdisp{background:#1e293b;color:#fff;padding:.15rem .55rem;border-radius:5px;font-family:monospace;font-size:.82rem;min-width:65px;text-align:center;border-bottom:3px solid #0f172a;transition:all .1s;}
.kdisp.pressed{background:var(--pri);border-bottom-color:var(--pri-d);transform:translateY(2px);}
.sandbox{border:2px dashed var(--bdr);border-radius:var(--r);padding:1.25rem;margin-bottom:1rem;min-height:80px;}
.exbtns{display:flex;flex-wrap:wrap;gap:.65rem;}
.exbtn{padding:.55rem 1.1rem;border-radius:var(--r);border:2px solid var(--bdr);background:var(--sur);color:var(--txt);font-size:.875rem;cursor:pointer;transition:all .15s;font-family:inherit;}
.exbtn:hover{border-color:var(--pri);color:var(--pri);}
.exbtn.target{border-color:var(--war);background:var(--war-l);}
.exbtn.activated{border-color:var(--suc);background:var(--suc-l);color:#065f46;}
.steplist{list-style:none;margin-bottom:.85rem;}
.steplist li{display:flex;align-items:center;gap:.5rem;padding:.35rem 0;font-size:.83rem;color:var(--muted);border-bottom:1px solid var(--bdr);}
.steplist li:last-child{border-bottom:none;}
.steplist li::before{content:'○';flex-shrink:0;color:var(--muted);}
.steplist li.done{color:var(--suc);}
.steplist li.done::before{content:'✓';color:var(--suc);font-weight:700;}
.exstatus{border-radius:var(--r);padding:.65rem .9rem;display:flex;align-items:center;gap:.65rem;font-size:.83rem;}
.exstatus.pending{background:var(--bg);border:1px solid var(--bdr);color:var(--muted);}
.exstatus.success{background:var(--suc-l);border:1px solid #6ee7b7;color:#065f46;}
.exstatus.error{background:var(--err-l);border:1px solid #fca5a5;color:#7f1d1d;}
.exstatus.hint{background:var(--war-l);border:1px solid #fcd34d;color:#78350f;}
.stic{font-size:1rem;flex-shrink:0;}
.skip-link{font-size:.78rem;color:var(--muted);text-decoration:underline;cursor:pointer;background:none;border:none;padding:0;margin-top:.5rem;display:inline-block;}
.skip-link:hover{color:var(--pri);}

/* FORM EXERCISE */
.exform{display:flex;flex-direction:column;gap:.85rem;}
.exfg{display:flex;flex-direction:column;gap:.2rem;}
.exfg label{font-size:.83rem;font-weight:600;}
.exfg input,.exfg select,.exfg textarea{padding:.45rem .7rem;border:2px solid var(--bdr);border-radius:var(--r);font-size:.875rem;transition:border-color .15s;font-family:inherit;}
.exfg input:focus,.exfg select:focus{border-color:var(--pri);outline:none;box-shadow:0 0 0 3px rgba(99,102,241,.15);}
.cbg{display:flex;align-items:center;gap:.5rem;}
.cbg input[type=checkbox]{width:17px;height:17px;cursor:pointer;}
.radio-grp{display:flex;flex-direction:column;gap:.4rem;}
.ropt{display:flex;align-items:center;gap:.65rem;padding:.5rem .7rem;border:2px solid var(--bdr);border-radius:var(--r);cursor:pointer;transition:all .15s;}
.ropt:focus-within{border-color:var(--pri);background:var(--pri-l);}

/* TABLE EXERCISE */
.tbl-wrap{overflow-x:auto;}
.dtbl{width:100%;border-collapse:collapse;font-size:.85rem;}
.dtbl th{background:var(--pri-l);color:var(--pri-d);font-weight:700;padding:.55rem .7rem;text-align:left;border:1px solid var(--bdr);}
.dtbl td{padding:.45rem .7rem;border:1px solid var(--bdr);transition:background .15s;}
.dtbl tr:nth-child(even) td{background:var(--bg);}
.dtbl td:focus{outline:3px solid var(--pri);background:var(--pri-l)!important;}
.dtbl caption{font-weight:700;text-align:left;padding:.4rem 0;font-size:.83rem;color:var(--muted);caption-side:top;}

/* MODAL */
.modback{position:fixed;inset:0;background:rgba(0,0,0,.55);display:flex;align-items:center;justify-content:center;z-index:200;padding:1rem;}
.moddlg{background:var(--sur);border-radius:12px;padding:1.75rem;max-width:380px;width:100%;box-shadow:0 25px 60px rgba(0,0,0,.25);}
.moddlg h3{font-size:1.15rem;font-weight:700;margin-bottom:.6rem;}
.moddlg p{color:var(--muted);margin-bottom:1.25rem;font-size:.9rem;}

/* BUTTONS */
.btn{padding:.55rem 1.2rem;border-radius:var(--r);font-size:.88rem;font-weight:600;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:.35rem;border:2px solid transparent;font-family:inherit;}
.btnp{background:var(--pri);color:#fff;}
.btnp:hover{background:var(--pri-d);}
.btns{background:transparent;border-color:var(--bdr);color:var(--txt);}
.btns:hover{border-color:var(--pri);color:var(--pri);}
.btn:disabled{opacity:.45;cursor:not-allowed;}

/* CELEBRATE */
@keyframes celebrate{0%{transform:scale(1);}50%{transform:scale(1.04);}100%{transform:scale(1);}}
.exarea.done{animation:celebrate .4s ease;border-color:var(--suc);}
.exarea.done .exhdr{background:var(--suc-l);border-color:var(--suc);}
.exarea.done .exhdr h3{color:#065f46;}

/* VO PRACTICE CHECKLIST */
.vo-practice{background:var(--sur);border:2px solid var(--pri);border-radius:var(--r);margin-bottom:1.25rem;overflow:hidden;}
.vo-steps{list-style:none;padding:.5rem 1.25rem;}
.vo-step{display:flex;align-items:center;justify-content:space-between;gap:.75rem;padding:.6rem 0;border-bottom:1px solid var(--bdr);}
.vo-step:last-child{border-bottom:none;}
.vo-step-info{display:flex;align-items:center;gap:.65rem;flex:1;}
.vo-step-cmd{background:#1e293b;color:#fff;border-radius:5px;padding:.12rem .45rem;font-family:monospace;font-size:.78rem;font-weight:600;border-bottom:3px solid #0f172a;white-space:nowrap;flex-shrink:0;}
.vo-step-label{font-size:.83rem;color:var(--txt);}
.vo-check-btn{background:var(--sur);border:2px solid var(--bdr);border-radius:var(--r);padding:.3rem .75rem;font-size:.78rem;font-weight:600;cursor:pointer;color:var(--muted);transition:all .15s;white-space:nowrap;flex-shrink:0;}
.vo-check-btn:hover{border-color:var(--suc);color:var(--suc);}
.vo-check-btn:disabled{opacity:.4;cursor:not-allowed;}
.vo-step-done .vo-step-label{color:var(--suc);text-decoration:line-through;}
.vo-step-done .vo-step-cmd{background:var(--suc);border-bottom-color:#059669;}

/* MOBILE */
@media(max-width:768px){
  .sidebar{position:fixed;top:0;left:0;height:100vh;z-index:50;transform:translateX(-100%);transition:transform .3s ease;width:280px;}
  .sidebar.open{transform:translateX(0);box-shadow:0 0 0 100vmax rgba(0,0,0,.5);}
  .app{flex-direction:row;}
  .lbody{padding:1rem;}
  .lfooter{padding:1rem;}
  .wtopics{grid-template-columns:1fr;}
  .cgrid,.ggrid{grid-template-columns:1fr;}
  .wcard{padding:2rem 1.25rem;}
  .wcard h1{font-size:1.5rem;}
}
</style>
</head>
<body>

<!-- WELCOME -->
<div id="welcome" class="welcome">
  <div class="wcard">
    <div class="wi">♿</div>
    <h1>Accessibility Tutorial</h1>
    <p>Learn to navigate the web using keyboard controls, screen readers, and mobile assistive technologies — step by step.</p>
    <div class="wtopics">
      <div class="wtopic"><div class="ti">⌨️</div><p>Keyboard Navigation</p></div>
      <div class="wtopic"><div class="ti">🖥️</div><p>macOS VoiceOver</p></div>
      <div class="wtopic"><div class="ti">📱</div><p>Mobile Screen Readers</p></div>
    </div>
    <p class="wmeta">17 lessons · Progressive difficulty · Interactive exercises</p>
    <button class="btn-start" onclick="startTutorial()">Start Learning →</button>
  </div>
</div>

<!-- APP -->
<div id="app" class="app hidden">
  <nav id="sidebar" class="sidebar" aria-label="Lesson navigation">
    <div class="sh">
      <span class="sh-title">A11y Tutorial</span>
      <button class="sh-close" onclick="toggleSidebar()" aria-label="Close menu">✕</button>
    </div>
    <div class="sp">
      <div class="sp-lbl"><span>Progress</span><span id="plbl">0 / 17</span></div>
      <div class="sp-bar"><div class="sp-fill" id="pbar" style="width:0%"></div></div>
    </div>
    <div class="snav" id="snav" role="list"></div>
  </nav>
  <div class="main" id="main">
    <div class="mhdr">
      <button class="mtog" onclick="toggleSidebar()" aria-label="Open lesson menu">☰</button>
      <div class="mhdr-info">
        <div class="mhdr-ch" id="hch">Chapter 1 · Keyboard Navigation</div>
        <div class="mhdr-t" id="ht">Introduction</div>
      </div>
      <div class="mhdr-p" id="hp">Lesson 1 of 18</div>
    </div>
    <div class="lbody" id="lbody"></div>
    <div class="lfooter">
      <button class="btn btns" id="bprev" onclick="navLesson(-1)">← Previous</button>
      <button class="btn btnp" id="bnext" onclick="navLesson(1)">Next Lesson →</button>
    </div>
  </div>
</div>

<script>
// ===== STATE =====
let cur = 0, done = new Set(), exDone = false, keyHandler = null;

const chapters = [
  {id:1,title:'Keyboard Navigation',icon:'⌨️'},
  {id:2,title:'VoiceOver on macOS',icon:'🖥️'},
  {id:3,title:'Mobile Screen Readers',icon:'📱'}
];

// ===== HELPERS =====
function K(k){return`<kbd>${k}</kbd>`;}
function dbadge(d){if(!d)return'';const m={easy:['be','🟢 Easy'],medium:['bm','🟡 Medium'],hard:['bh','🔴 Hard']};return`<span class="badge ${m[d][0]}">${m[d][1]}</span>`;}
function ibox(t,ic,c){return`<div class="ibox ${t}"><span class="ibox-ic">${ic}</span><div class="ibox-c">${c}</div></div>`;}
function CC(keys,desc){const kh=keys.map(k=>`<kbd>${k}</kbd>`).join(' <span style="color:var(--muted);font-size:.75rem">+</span> ');return`<div class="ccard"><div class="ckeys">${kh}</div><div class="cdesc">${desc}</div></div>`;}
function GC(ic,ttl,desc){return`<div class="gcard"><div class="gic">${ic}</div><div class="ginf"><h4>${ttl}</h4><p>${desc}</p></div></div>`;}
function ST(t){return`<div class="stitle">${t}</div>`;}

function setKH(fn){
  if(keyHandler)document.removeEventListener('keydown',keyHandler);
  keyHandler=fn;
  if(fn)document.addEventListener('keydown',fn);
}
function clearKH(){setKH(null);}

function showKey(k){
  const el=document.getElementById('kd');
  if(!el)return;
  el.textContent=k;el.classList.add('pressed');
  setTimeout(()=>el&&el.classList.remove('pressed'),200);
}
function markStep(id){const el=document.getElementById('s_'+id);if(el)el.classList.add('done');}
function exStatus(type,ic,msg){
  const el=document.getElementById('exst');if(!el)return;
  el.className=`exstatus ${type}`;
  el.querySelector('.stic').textContent=ic;
  el.querySelector('#stxt').textContent=msg;
}
function completeEx(){
  exDone=true;done.add(cur);
  const ea=document.getElementById('exarea');if(ea)ea.classList.add('done');
  const eh=document.getElementById('exhdr-icon');if(eh)eh.textContent='✅';
  exStatus('success','🎉','Exercise complete! Great work! Click "Next Lesson →" to continue.');
  updateUI();
  setTimeout(()=>{const nb=document.getElementById('bnext');if(nb)nb.focus();},300);
}
function skipEx(){exDone=true;done.add(cur);updateUI();exStatus('hint','⏭️','Exercise skipped. You can come back and try it anytime.');}

function exArea(title, taskHTML, sandboxHTML, steps){
  const stepsHTML = steps ? `<ul class="steplist" id="stl">${steps.map(s=>`<li id="s_${s.id}">${s.label}</li>`).join('')}</ul>` : '';
  return `<div class="exarea" id="exarea">
    <div class="exhdr"><span>🎯</span><h3 id="exh3">${title}</h3><span id="exhdr-icon">⏳</span></div>
    <div class="exbody">
      <div class="extask">${taskHTML}</div>
      <div class="keyind">Last key pressed: <span class="kdisp" id="kd">—</span></div>
      <div class="sandbox" id="esb">${sandboxHTML}</div>
      ${stepsHTML}
      <div class="exstatus pending" id="exst"><span class="stic">💡</span><span id="stxt">Complete the exercise above to continue.</span></div>
      <button class="skip-link" onclick="skipEx()">Skip this exercise →</button>
    </div>
  </div>`;
}

// ===== LESSONS =====
const lessons = [
  // CH1
  {id:1,ch:1,d:null,title:'Introduction to Keyboard Navigation',r:L1},
  {id:2,ch:1,d:'easy',title:'The Tab Key — Moving Forward',r:L2},
  {id:3,ch:1,d:'easy',title:'Shift+Tab — Moving Backward',r:L3},
  {id:4,ch:1,d:'easy',title:'Enter & Space — Activating Elements',r:L4},
