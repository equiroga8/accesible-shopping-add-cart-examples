// ===== CORE APP =====
function renderLesson(idx){
  clearKH();
  cur=idx;exDone=false;
  const L=lessons[idx];
  const body=document.getElementById('lbody');
  body.innerHTML='';
  const ch=chapters.find(c=>c.id===L.ch);
  document.getElementById('hch').textContent=`Chapter ${L.ch} · ${ch.title}`;
  document.getElementById('ht').textContent=L.title;
  document.getElementById('hp').textContent=`Lesson ${idx+1} of ${lessons.length}`;
  document.getElementById('bprev').disabled=idx===0;
  document.getElementById('bnext').disabled=idx===lessons.length-1;
  L.r(body);
  updateUI();
  document.getElementById('main').scrollTo(0,0);
}

function navLesson(dir){
  const ni=cur+dir;
  if(ni<0||ni>=lessons.length)return;
  if(!exDone&&lessons[cur].r!==L1){
    // allow navigation but don't auto-complete exercises
  }
  done.add(cur);
  renderLesson(ni);
}

function goTo(idx){
  done.add(cur);
  renderLesson(idx);
  if(window.innerWidth<=768)document.getElementById('sidebar').classList.remove('open');
}

function updateUI(){
  // sidebar
  const nav=document.getElementById('snav');
  let html='',lastCh=null;
  lessons.forEach((L,i)=>{
    if(L.ch!==lastCh){
      lastCh=L.ch;
      const ch=chapters.find(c=>c.id===L.ch);
      html+=`<div class="chdr">${ch.icon} ${ch.title}</div>`;
    }
    const isA=i===cur, isDone=done.has(i);
    html+=`<button class="litem${isA?' active':''}${isDone?' done':''}" onclick="goTo(${i})" role="listitem" aria-current="${isA?'page':'false'}">
      <span class="lstatus">${isDone?'✓':isA?'▶':''}</span>
      <span class="ltext">${L.title}</span>
    </button>`;
  });
  nav.innerHTML=html;
  // progress
  const total=lessons.length, ndone=done.size, pct=Math.round(ndone/total*100);
  document.getElementById('pbar').style.width=pct+'%';
  document.getElementById('plbl').textContent=`${ndone} / ${total}`;
}

function toggleSidebar(){
  const sb=document.getElementById('sidebar');
  if(window.innerWidth<=768)sb.classList.toggle('open');
  else sb.classList.toggle('collapsed');
}

function startTutorial(){
  document.getElementById('welcome').classList.add('hidden');
  document.getElementById('app').classList.remove('hidden');
  updateUI();
  renderLesson(0);
  document.getElementById('main').focus();
}
</script>
