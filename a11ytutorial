// --- L6 ---
function L6(c){
  exDone=false;
  let mopen=false;
  c.innerHTML=`<div class="lcontent">
    <h2>Escape — Closing & Canceling</h2>
    <div class="lmeta"><span class="badge bc">Chapter 1 · Keyboard Navigation</span>${dbadge('medium')}</div>
    <div class="intro">
      <p>The ${K('Escape')} key is the universal <em>"get me out"</em> key. It must close: modal dialogs, dropdown menus, tooltips, popovers, and any overlay.</p>
      <p>When a modal closes, <strong>focus must return</strong> to the trigger element. This is a critical UX requirement for keyboard users.</p>
    </div>
    ${ibox('note','ℹ️',`<strong>Focus trap:</strong> While a modal is open, Tab should cycle only through the modal's interactive elements — it must not leave the dialog until it's dismissed.`)}
    ${exArea(
      'Escape Key Challenge',
      `<p><strong>Task:</strong> Activate the "Open Dialog" button. When the modal appears, press ${K('Escape')} to close it. Notice where focus goes!</p>`,
      `<div style="text-align:center;padding:.5rem">
        <button class="exbtn" id="openbtn" onclick="openM6()">📂 Open Dialog</button>
      </div>`,
      [{id:'m1',label:'Open the dialog'},{id:'m2',label:'Press Escape to close it'},{id:'m3',label:'Notice focus returns to trigger'}]
    )}
  </div>`;

  window.openM6=function(){
    if(document.getElementById('exmod'))return;
    mopen=true;markStep('m1');
    exStatus('hint','💡','Modal is open! Press Escape to close it.');
    const mod=document.createElement('div');
    mod.className='modback';mod.id='exmod';
    mod.setAttribute('role','dialog');mod.setAttribute('aria-modal','true');mod.setAttribute('aria-labelledby','mttl');
    mod.innerHTML=`<div class="moddlg">
      <h3 id="mttl">🎉 Modal Dialog</h3>
      <p>While this modal is open, focus should stay trapped inside. Press <strong>Escape</strong> to close it, or use the Cancel button.</p>
      <div style="display:flex;gap:.5rem">
        <button class="btn btns" id="mcanc" onclick="closeM6(false)">Cancel</button>
        <button class="btn btnp" id="mconf" onclick="closeM6(false)">Confirm</button>
      </div>
    </div>`;
    document.body.appendChild(mod);
    // Focus trap
    const focusable=mod.querySelectorAll('button');
    focusable[0].focus();
    mod.addEventListener('keydown',function(e){
      if(e.key==='Escape'){e.preventDefault();closeM6(true);return;}
      if(e.key==='Tab'){
        e.preventDefault();
        const fs=[...focusable];
        const idx=fs.indexOf(document.activeElement);
        const next=e.shiftKey?(idx-1+fs.length)%fs.length:(idx+1)%fs.length;
        fs[next].focus();
      }
    });
  };
  window.closeM6=function(fromEsc){
    const m=document.getElementById('exmod');
    if(m){m.remove();mopen=false;setTimeout(()=>{const ob=document.getElementById('openbtn');if(ob)ob.focus();},0);}
    if(fromEsc){markStep('m2');markStep('m3');completeEx();clearKH();}
  };
  setKH(function(e){
    if(!document.getElementById('exarea')){clearKH();return;}
    if(e.key==='Escape'){e.preventDefault();showKey('Esc');if(mopen){clearKH();closeM6(true);}}
    else if(e.key==='Tab')showKey('Tab');
  });
}

