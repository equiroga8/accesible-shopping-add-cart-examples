      <button class="vo-check-btn" onclick="voMark('${id}','${s.id}',${steps.length})" aria-label="Mark step done">✓ Done</button>
    </li>`).join('');
  return `<div class="vo-practice" id="vop_${id}">
    <div class="exhdr" style="border-radius:var(--r) var(--r) 0 0;border:2px solid var(--pri);border-bottom:2px solid var(--pri)"><span>🎙️</span><h3>Practice with VoiceOver — follow each step</h3><span id="vo_icon_${id}">⏳</span></div>
